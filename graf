set datafile separator ","
set autoscale fix
#set key inside right corner 

set xdata time
set timefm "%H:%M:%S"
set format x "%H:%M:%S"

set style line 100 lt 1 lc rgb "grey" lw 0.5 # linestyle for the grid
set grid ls 100 # enable grid with specific linestyle

set title "cansat ProximaAerospace"

while (1) {
set size 1,1
set origin 0,0
set multiplot layout 2,3 
plot 'file.csv' using 2:6 with lines title "teplota", 
plot 'file.csv' using 2:7 with lines title "tlak"
plot 'file.csv' using 2:5 with lines title "výška"
plot 'file.csv' using 2:8 with lines title "rssi"
unset multiplot
pause 1
}
