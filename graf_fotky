set datafile separator ","
set autoscale fix
#set key inside right corner 

set xdata time
set timefm "%H:%M:%S"
set format x "%H:%M:%S"

set style line 100 lt 1 lc rgb "grey" lw 1 # linestyle for the grid
set grid ls 100 # enable grid with specific linestyle

set title "cansat ProximaAerospace"
set key font "Arial Bold"

#nastavenie od do kedy
set xrange ["13:48:0.0":"13:49:0.0"]
show xrange


#format obrázka
#set terminal png font giant size 1024, 768

set terminal svg enhanced font "Ariali,32" size 2048, 1536 background "#ffffff"



set output "teplota.svg" 
plot 'file.csv' using 2:6 with lines title "Teplota °C" lc rgb "#F50048" lw 4 
 
set output "tlak.svg"
plot 'file.csv' using 2:7 with lines title "Tlak hPa" lc rgb "#CC9600" lw 4 

set output "výška.svg"
plot 'file.csv' using 2:5 with lines title "Výška m n.m." lc rgb "#00F51D" lw 4 

set output "rssi.svg"
plot 'file.csv' using 2:8 with lines title "RSSI dbm" lc rgb "#35A042" lw 4 

unset style line
unset key
